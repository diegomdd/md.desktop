{
  "name": "md.desktop",
  "version": "0.1.0",
  "description": "Native desktop Markdown editor and viewer for Windows",
  "productName": "md.desktop",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder --win nsis portable"
  },
  "keywords": [
    "markdown",
    "electron",
    "desktop",
    "windows"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "marked": "^16.4.0"
  },
  "devDependencies": {
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.diegomdd.md.desktop",
    "productName": "md.desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/marked/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "executableName": "md-desktop"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    }
  }
}
